{
  "name": "@inertia-phoenix",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Inertia.js adapter for Phoenix LiveView",
  "author": "Derrick Reimer",
  "repository": {
    "type": "git",
    "url": "git://github.com/inertiajs/inertia-phoenix.git"
  },
  "type": "module",
  "scripts": {
    "copyPackage": "cp package.json ../package.json",
    "dev": "npm run copyPackage && tsc --watch",
    "build": "rm -rf priv/vitejs && npm run copyPackage && vite build",
    "format": "npx prettier --write assets"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "prettier": "2.8.7",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  },
  "exports": {
    "./vitePlugin": {
      "import": "./priv/vitejs/vitePlugin.js",
      "types": "./priv/vitejs/vitePlugin.d.ts"
    }
  },
  "files": [
    "package.json",
    "./priv/vitejs/vitePlugin.js",
    "./priv/vitejs/vitePlugin.d.ts"
  ]
}
